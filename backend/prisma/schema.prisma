  documentType EmployeeDocumentType
  documentName String
  fileUrl      String?
  expiryDate   DateTime?
  status       EmployeeDocumentStatus @default(PENDING)
  notes        String?
  uploadedById Int

  // Phase 5.10 — Digital signature for compliance docs
  requiresSignature Boolean   @default(false)
  signedAt          DateTime?
  signedById        Int?
  signatureText     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
}

model LeaveBalance {
