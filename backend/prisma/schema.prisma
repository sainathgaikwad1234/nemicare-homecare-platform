  passedDate    DateTime?
  expiryDate    DateTime?
  status        EmployeeTestStatus @default(PENDING)
  fileUrl       String?
  notes         String?
  recordedById  Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([employeeId, testType])
  @@index([expiryDate])
  @@index([status])
}

enum EmployeeTestType {
  TB_TEST
  DRUG_SCREEN
  PHYSICAL_EXAM
  FINGERPRINT_DMV
  CPR_CERTIFICATION
  HIV_TEST
  COVID_TEST
  HEPATITIS_B
  OTHER
}

enum EmployeeTestStatus {
  PENDING       // scheduled but not yet completed
  PASSED
  FAILED
  EXPIRED
  WAIVED
}

model BgCheckDispatch {
  id              Int      @id @default(autoincrement())
  companyId       Int
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  agencyId        Int?
  agency          BackgroundCheckAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  consentDate     DateTime
  dispatchedAt    DateTime @default(now())
  dispatchedById  Int?
  reportReceivedAt DateTime?
  reportFileUrl   String?
  status          BgCheckDispatchStatus @default(SENT)
  notes           String?

  @@index([employeeId])
  @@index([status])
}

enum BgCheckDispatchStatus {
  SENT
  IN_PROGRESS
  REPORT_RECEIVED
  CLEARED
  FAILED
  CANCELLED
}

// ============================================
// SPRINT 5.8 — Internal Messaging
// ============================================

model MessageThread {
  id          Int       @id @default(autoincrement())
  companyId   Int
  subject     String?
  // For 1:1 threads, participants are stored in MessageThreadParticipant
  threadType  MessageThreadType @default(DIRECT)
  lastMessageAt DateTime @default(now())
  createdById Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participants MessageThreadParticipant[]
  messages     Message[]

  @@index([companyId])
  @@index([lastMessageAt])
}

enum MessageThreadType {
  DIRECT
  DEPARTMENT
  ANNOUNCEMENT
}

model MessageThreadParticipant {
  id        Int           @id @default(autoincrement())
  threadId  Int
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    Int
  joinedAt  DateTime      @default(now())
  lastReadAt DateTime?

  @@unique([threadId, userId])
  @@index([userId])
}

model Message {
  id        Int           @id @default(autoincrement())
  threadId  Int
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  Int
  body      String
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

// ============================================
// PHASE 5.10 — Closing remaining gaps from project docs
// ============================================

model IncidentReport {
  id                 Int                 @id @default(autoincrement())
  companyId          Int
  facilityId         Int?
  reportedById       Int                 // user id (supervisor / HR)
  involvedEmployeeId Int?                // employee involved (optional)
  incidentDate       DateTime
  category           IncidentCategory
  severity           IncidentSeverity
  title              String
  description        String
  actionTaken        String?
  status             IncidentStatus      @default(OPEN)
  resolvedAt         DateTime?
  attachmentUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([involvedEmployeeId])
}

enum IncidentCategory {
  ATTENDANCE
  PERFORMANCE
  CONDUCT
  SAFETY
  POLICY_VIOLATION
  COMPLAINT
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

model EmployeeRecognition {
  id            Int      @id @default(autoincrement())
  companyId     Int
  employeeId    Int
  recognizedById Int     // recognizer (supervisor/HR/peer)
  category      String   // "Excellence" | "Teamwork" | "Innovation" | etc.
  title         String
  description   String?
  visibility    String   @default("TEAM") // TEAM | PUBLIC | PRIVATE
  createdAt     DateTime @default(now())

  @@index([employeeId])
  @@index([recognizedById])
}

model CompanyPayrollSettings {
  id                  Int      @id @default(autoincrement())
  companyId           Int      @unique
  payPeriodType       String   @default("BIWEEKLY") // WEEKLY | BIWEEKLY | SEMIMONTHLY | MONTHLY
  workweekStartDay    Int      @default(1) // 0=Sunday..6=Saturday
  dailyOtThresholdHours    Decimal @default(8)
  weeklyOtThresholdHours   Decimal @default(40)
  doubletimeThresholdHours Decimal @default(12)
  nightShiftDifferentialPercent  Decimal @default(0)  // % bonus for THIRD shifts
  weekendDifferentialPercent     Decimal @default(0)  // % bonus for Sat/Sun
  holidayMultiplier              Decimal @default(2.0) // 2x for holidays
  payrollProvider                String  @default("ADP") // ADP | GUSTO | PAYCHEX | QUICKBOOKS

  updatedAt DateTime @updatedAt
  updatedById Int?
}


// ============================================
// FAMILY PORTAL
// ============================================

model FamilyResidentLink {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("FamilyContactLinks", fields: [userId], references: [id], onDelete: Cascade)
  residentId   Int
  resident     Resident @relation("FamilyContactLinks", fields: [residentId], references: [id], onDelete: Cascade)
  companyId    Int
  relation     String   // Brother, Sister, Daughter, Son, Spouse, Other
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, residentId])
  @@index([userId])
  @@index([residentId])
}


// ============================================
// FAMILY PORTAL — Appointments + Notifications
// ============================================

enum AppointmentMode {
  IN_PERSON
  VIRTUAL
}

enum AppointmentStatus {
  REQUESTED   // family submitted, staff hasn't confirmed
  SCHEDULED   // confirmed by staff
  COMPLETED
  CANCELLED
}

model FamilyAppointment {
  id              Int               @id @default(autoincrement())
  companyId       Int
  residentId      Int
  resident        Resident          @relation("FamilyAppointments", fields: [residentId], references: [id], onDelete: Cascade)
  requestedById   Int               // family contact user
  requestedBy     User              @relation("FamilyAppointmentRequests", fields: [requestedById], references: [id], onDelete: Cascade)

  mode            AppointmentMode   @default(IN_PERSON)
  status          AppointmentStatus @default(REQUESTED)

  scheduledDate   DateTime
  scheduledTime   String            // "HH:MM-HH:MM" range
  durationMinutes Int               @default(60)

  preferredProvider String?
  assignedProviderId Int?
  reason          String?
  notes           String?

  facilityName    String?
  facilityAddress String?
  telehealthUrl   String?

  cancelledAt     DateTime?
  cancelledReason String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([residentId])
  @@index([requestedById])
  @@index([status])
  @@index([scheduledDate])
}

enum FamilyNotificationType {
  PASSWORD
  DOCUMENT
  ALERT
  INCIDENT
  MESSAGE
  TICKET
  INVOICE
  APPOINTMENT
}

model FamilyNotification {
  id          Int                    @id @default(autoincrement())
  companyId   Int
  userId      Int                    // recipient family contact
  user        User                   @relation("FamilyNotifications", fields: [userId], references: [id], onDelete: Cascade)
  residentId  Int?                   // optional resident scope
  type        FamilyNotificationType
  title       String
  description String?
  link        String?                // optional deep link
  readAt      DateTime?
  createdAt   DateTime               @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

model FamilyNotificationSetting {
  id      Int                       @id @default(autoincrement())
  userId  Int                       @unique
  user    User                      @relation("FamilyNotificationSettings", fields: [userId], references: [id], onDelete: Cascade)
  // Per-type opt-in flags; default everything ON
  password    Boolean @default(true)
  document    Boolean @default(true)
  alert       Boolean @default(true)
  incident    Boolean @default(true)
  message     Boolean @default(true)
  ticket      Boolean @default(true)
  invoice     Boolean @default(true)
  appointment Boolean @default(true)
  allowAll    Boolean @default(true)
  updatedAt   DateTime @updatedAt
}
