  PARTIAL
  FAILED
}

// ============================================
// SPRINT 5.3 — Shift Change Request
// (Per workflow diagram: Employee submits change → Supervisor approves → roster updates)
// ============================================

model ShiftChangeRequest {
  id                 Int                 @id @default(autoincrement())
  companyId          Int
  employeeId         Int
  employee           Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  originalShiftId    Int
  originalShift      ShiftSchedule       @relation("ShiftChangeOriginal", fields: [originalShiftId], references: [id], onDelete: Cascade)
  requestedDate      DateTime?           // null = swap to OFF; non-null = move to this date
  requestedShiftType ShiftType?          // null = keep original type
  requestedStartTime String?
  requestedEndTime   String?
  reason             String              // required
  status             ShiftChangeStatus   @default(PENDING)
  decidedById        Int?
  decidedAt          DateTime?
  rejectionReason    String?

  // Phase 5.10 — Peer-to-peer swap (optional target employee)
  targetEmployeeId    Int?
  targetAcceptedAt    DateTime?
  targetDeclinedAt    DateTime?
  targetDeclineReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([originalShiftId])
  @@index([status])
  @@index([targetEmployeeId])
}

enum ShiftChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

