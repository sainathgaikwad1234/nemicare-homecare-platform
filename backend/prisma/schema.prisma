  sickBalance     Decimal @default(0)
  personalBalance Decimal @default(0)
  unpaidBalance   Decimal @default(0)

  year Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  leaveType LeaveType
  fromDate  DateTime
  toDate    DateTime
  totalDays Decimal
  reason    String?
  status    LeaveStatus @default(PENDING)

  approvedById          Int?
  approvedAt            DateTime?
  rejectionReason       String?
  replacementEmployeeId Int?

  // Phase 2: Dual-approval workflow
  supervisorApprovalStatus DualApprovalStatus @default(PENDING)
  supervisorApprovedById   Int?
  supervisorApprovedAt     DateTime?
  hrApprovalStatus         DualApprovalStatus @default(WAITING)
  hrApprovedById           Int?
  hrApprovedAt             DateTime?

  // Sprint 5.4: Need-Info loopback (supervisor asks employee for clarification)
  infoRequestMessage  String?
  infoRequestedById   Int?
  infoRequestedAt     DateTime?
  infoResponseMessage String?
  infoRespondedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([fromDate, toDate])
  @@index([supervisorApprovalStatus])
  @@index([hrApprovalStatus])
}

enum DualApprovalStatus {
  WAITING      // not yet eligible (HR is WAITING until supervisor decides)
  PENDING      // awaiting decision
  APPROVED
  REJECTED
}

model ShiftSchedule {
