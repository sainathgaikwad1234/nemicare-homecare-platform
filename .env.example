# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# SERVER
# ============================================
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nemicare_dev

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Change these to strong random values in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-12345

# Password configuration
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_ROUNDS=10

# Account lockout (after N failed attempts)
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# ============================================
# RATE LIMITING
# ============================================
# Requests per 15-minute window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CACHE & QUEUE (Redis)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# EMAIL SERVICE (SendGrid)
# ============================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx-xxxxxx
SENDGRID_FROM_EMAIL=noreply@nemicare.io

# ============================================
# SMS SERVICE (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ============================================
# PAYMENT PROCESSING (Stripe)
# ============================================
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ============================================
# PAYMENT PROCESSING (Square)
# ============================================
SQUARE_ACCESS_TOKEN=sq0atp_xxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_ENVIRONMENT=sandbox

# ============================================
# DOCUMENT SIGNATURES (DocuSign)
# ============================================
DOCUSIGN_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_CLIENT_SECRET=xxxxxxxxxxxxxxxx
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=xxxxxxxx

# ============================================
# FILE STORAGE (AWS S3)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=nemicare-documents
AWS_S3_PREFIX=documents/

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Sentry error tracking
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production

# DataDog APM (optional)
DD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DD_ENV=production
DD_SERVICE=nemicare-backend
DD_TRACE_ENABLED=false

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================

# Medicaid & Healthcare Integration (Verida)
VERIDA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
VERIDA_BASE_URL=https://api.verida.io/v1

# Ring Central (for phone/fax)
RINGCENTRAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
RINGCENTRAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RINGCENTRAL_EXTENSION=101

# ============================================
# FEATURE FLAGS (Phase 1, 2, 3)
# ============================================
FEATURES_PHASE_1_ENABLED=true
FEATURES_PHASE_2_ENABLED=false
FEATURES_PHASE_3_ENABLED=false

# Lead management
FEATURE_LEAD_SCORING=true
FEATURE_LEAD_AUTO_NURTURE=false

# Resident management
FEATURE_RESIDENT_LIFECYCLE=true
FEATURE_RESIDENT_DISCHARGE_WORKFLOW=false

# Billing
FEATURE_BILLING_MEDICAID=true
FEATURE_BILLING_PRIVATE_PAY=true
FEATURE_BILLING_INSURANCE=false
FEATURE_BILLING_AUTO_SUBMISSION=false

# Clinical
FEATURE_CLINICAL_CHARTING=true
FEATURE_CLINICAL_VITAL_SIGNS=true
FEATURE_CLINICAL_MEDICATION_TRACKING=false

# HIPAA & Compliance
FEATURE_HIPAA_AUDIT_LOGGING=true
FEATURE_HIPAA_ENCRYPTION=true
FEATURE_HIPAA_ACCESS_CONTROLS=true

# ============================================
# HIPAA COMPLIANCE SETTINGS
# ============================================
HIPAA_ENCRYPTION_ENABLED=true
HIPAA_AUDIT_RETENTION_DAYS=2555  # 7 years
HIPAA_SESSION_TIMEOUT_MINUTES=30
HIPAA_PASSWORD_EXPIRY_DAYS=90
HIPAA_MFA_REQUIRED=false  # Enable in production

# ============================================
# DEBUG & DEVELOPMENT
# ============================================
DEBUG=nemicare:*
VERBOSE_LOGGING=false
SEED_DATABASE_ON_STARTUP=false  # Set to true to auto-seed on dev start
